<Window x:Class="Clppy.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Clppy.App"
        Title="Clppy" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Closing="MainWindow_Closing" KeyDown="MainWindow_KeyDown">
    <Window.Resources>
        <Style x:Key="HistoryZoneStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFF0E68C"/>
        </Style>
        <Style x:Key="ClipCellStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFF5F5F5"/>
            <Setter Property="BorderBrush" Value="#FFCCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Margin" Value="2"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Filter Overlay -->
        <Border x:Name="FilterOverlay"
                Grid.Row="0"
                Background="#80000000"
                Visibility="Collapsed"
                VerticalAlignment="Top"
                Height="60">
            <Grid Background="White" Margin="20">
                <TextBox x:Name="FilterTextBox"
                         Height="30"
                         VerticalAlignment="Center"
                         TextChanged="FilterTextBox_TextChanged"
                         PreviewKeyDown="FilterTextBox_PreviewKeyDown"/>
            </Grid>
        </Border>

        <!-- Main Grid View -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ClipGrid" ItemsSource="{Binding Clips}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid x:Name="ClipUniformGrid" Columns="9" Rows="30"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ClipCellStyle}"
                                Background="{Binding BackgroundBrush}"
                                MouseLeftButtonUp="ClipCell_MouseLeftButtonUp"
                                MouseLeftButtonDown="ClipCell_MouseLeftButtonDown"
                                MouseDoubleClick="ClipCell_MouseDoubleClick"
                                MouseRightButtonUp="ClipCell_MouseRightButtonUp"
                                MouseMove="ClipCell_MouseMove"
                                AllowDrop="True"
                                Drop="ClipCell_Drop"
                                DragOver="ClipCell_DragOver">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="{Binding Label}" 
                                           FontWeight="SemiBold" FontSize="11"/>
                                <TextBlock Grid.Row="1" Text="{Binding Preview}" 
                                           FontSize="9" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Row="0" Grid.RowSpan="2" 
                                           Text="{Binding MethodIcon}" 
                                           FontSize="10" 
                                           HorizontalAlignment="Right" VerticalAlignment="Top"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
