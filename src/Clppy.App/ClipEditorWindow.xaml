<Window x:Class="Clppy.App.ClipEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Clip" Height="400" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Label -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Label:" VerticalAlignment="Center"/>
            <TextBox x:Name="LabelTextBox" Grid.Column="1"/>
        </Grid>

        <!-- Plain Text Content -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Content:" VerticalAlignment="Top" Margin="0,5,0,0"/>
            <TextBox x:Name="ContentTextBox" 
                     Grid.Column="1" 
                     AcceptsReturn="True" 
                     AcceptsTab="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     PreviewKeyDown="ContentTextBox_PreviewKeyDown"
                     ContextMenu="ContentContextMenu"/>
        </Grid>

        <!-- Default Paste Method -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Method:" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <RadioButton x:Name="DirectMethodRadio" Content="Direct (▶)" IsChecked="True"/>
                <RadioButton x:Name="InjectMethodRadio" Content="Inject (⌨)" Margin="10,0,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Color -->
        <Grid Grid.Row="3" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Color:" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="ColorButton" Content="Pick Color" Width="80" Click="ColorButton_Click"/>
                <TextBlock x:Name="ColorTextBlock" Text="#F5F5F5" Margin="10,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Hotkey -->
        <Grid Grid.Row="4" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Hotkey:" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="HotkeyButton" Content="Capture" Width="80" Click="HotkeyButton_Click"/>
                <TextBlock x:Name="HotkeyTextBlock" Text="(none)" Margin="10,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Rich Text Indicator -->
        <Border x:Name="RichTextIndicator" 
                Grid.Row="5" 
                Background="#FFF0F0F0" 
                BorderBrush="#FFCCCCCC" 
                BorderThickness="1" 
                CornerRadius="4"
                Padding="10"
                Margin="0,0,0,10"
                Visibility="Collapsed">
            <TextBlock Text="Has rich-text formats (read-only)" Foreground="#FF6666"/>
        </Border>

        <!-- Buttons -->
        <Grid Grid.Row="7" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="SaveButton" Content="Save" Width="80" HorizontalAlignment="Right" Click="SaveButton_Click"/>
            <Button x:Name="CancelButton" Content="Cancel" Width="80" Margin="10,0,0,0" Click="CancelButton_Click"/>
        </Grid>
    </Grid>
</Window>
